# ── TinaCMS (get these from app.tina.io → your project) ──────────────────────
# IMPORTANT: NEXT_PUBLIC_ prefix exposes vars to the browser — only use for
# values that are safe to be public. Keep TINA_TOKEN server-side only.
NEXT_PUBLIC_TINA_CLIENT_ID=c3e4f675-607f-453f-92bd-09319ef63bce
TINA_TOKEN=4ef9120d1b2958214a3605122bd8beeeb8364857

# Branch TinaCMS reads/writes content from (auto-detected on Vercel)
GITHUB_BRANCH=main

# ── Analytics ─────────────────────────────────────────────────────────────────
# Add your GA4 measurement ID (also editable in TinaCMS → Site Settings)
# PUBLIC_ prefix is safe — this ID is meant to be in the HTML.
PUBLIC_GA_ID=

# ── Vercel ────────────────────────────────────────────────────────────────────
# These are auto-populated by Vercel — do NOT set manually.
# VERCEL_URL=
# VERCEL_GIT_COMMIT_REF=
