---
interface Service {
  icon: string;
  title: string;
  description: string;
  href: string;
  badge?: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  services?: Service[];
  compact?: boolean;
}

const defaultServices: Service[] = [
  {
    icon: '📱',
    title: 'App Development',
    description: 'Bespoke web and mobile apps — iOS, Android, and cross-platform — built with cutting-edge frameworks tailored to your business goals.',
    href: '/services/app-development/',
    badge: 'Most Popular',
  },
  {
    icon: '🌐',
    title: 'Website Development',
    description: 'High-performance, conversion-focused websites that represent your brand and drive results.',
    href: '/services/website-development/',
  },
  {
    icon: '📣',
    title: 'Digital Marketing',
    description: 'SEO, social media, email, paid ads, and video — full-funnel strategies that grow your audience and revenue.',
    href: '/services/digital-marketing/',
  },
  {
    icon: '🎨',
    title: 'UI/UX Design',
    description: 'Structurally and aesthetically stunning designs that deliver exceptional user experiences across every touchpoint.',
    href: '/services/ui-ux-design/',
  },
  {
    icon: '📊',
    title: 'Data Science & Analytics',
    description: 'Actionable insights from your data — from ETL pipelines to dashboards — that drive smarter business decisions.',
    href: '/services/data-science/',
  },
  {
    icon: '💡',
    title: 'Innovation Consulting',
    description: 'Strategic digital consulting to identify opportunities, define roadmaps, and execute with the right tech stack.',
    href: '/services/innovation-consulting/',
  },
];

const {
  heading = 'Everything You Need to Scale Digitally',
  subheading = 'End-to-end digital solutions — from strategy through deployment — all under one roof.',
  services = defaultServices,
  compact = false,
} = Astro.props;
---

<section class="section">
  <div class="container">
    <!-- Section Header -->
    {!compact && (
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="badge mb-4">Our Services</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4">{heading}</h2>
        <p class="text-brand-muted leading-relaxed">{subheading}</p>
      </div>
    )}

    <!-- Grid -->
    <div class:list={['grid gap-6', compact ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3']}>
      {services.map((service) => (
        <a href={service.href} class="card-hover group block relative">
          {service.badge && (
            <span class="absolute top-4 right-4 badge text-xs">{service.badge}</span>
          )}
          <div class="text-3xl mb-4">{service.icon}</div>
          <h3 class="font-semibold text-lg font-heading mb-2 group-hover:text-brand-accent transition-colors">
            {service.title}
          </h3>
          <p class="text-brand-muted text-sm leading-relaxed mb-4">{service.description}</p>
          <span class="text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
            Learn more
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
