---
interface Service {
  icon: string;
  title: string;
  description: string;
  href: string;
  badge?: string;
}

interface Props {
  heading?: string;
  subheading?: string;
  services?: Service[];
  compact?: boolean;
}

const defaultServices: Service[] = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>`,
    title: 'App development',
    description: 'Custom web and mobile apps — iOS, Android, and cross-platform — built from your real-world workflow, not a template.',
    href: '/services/app-development/',
    badge: 'Most popular',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    title: 'Website development',
    description: 'Fast, secure, SEO-ready websites your team can actually update — without calling a developer every time.',
    href: '/services/website-development/',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>`,
    title: 'Digital marketing',
    description: 'The full pipeline — SEO, paid ads, email, SMS — from the moment someone searches to the moment they become a customer.',
    href: '/services/digital-marketing/',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>`,
    title: 'UI/UX design',
    description: 'Interfaces that feel natural to your users and drive the specific actions your business needs — not just pretty mockups.',
    href: '/services/ui-ux-design/',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>`,
    title: 'Data science and analytics',
    description: 'Your data is talking — we turn it into clear insights and automated systems that drive smarter decisions.',
    href: '/services/data-science/',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    title: 'Innovation consulting',
    description: 'We help you figure out which technology investments will actually move the needle — and then we build them.',
    href: '/services/innovation-consulting/',
  },
];

const {
  heading = 'Everything you need to scale digitally',
  subheading = 'Three interconnected divisions — one team. Strategy, design, development, and marketing, all under one roof.',
  services = defaultServices,
  compact = false,
} = Astro.props;
---

<section class="section">
  <div class="container">
    <!-- Section Header -->
    {!compact && (
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="badge mb-4">Our services</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4">{heading}</h2>
        <p class="text-brand-muted leading-relaxed">{subheading}</p>
      </div>
    )}

    <!-- Grid -->
    <div class:list={['grid gap-6', compact ? 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3']}>
      {services.map((service) => (
        <a href={service.href} class="card-hover group block relative">
          {service.badge && (
            <span class="absolute top-4 right-4 badge text-xs">{service.badge}</span>
          )}
          <div class="mb-4 text-brand-accent" set:html={service.icon} />
          <h3 class="font-semibold text-lg font-heading mb-2 group-hover:text-brand-accent transition-colors">
            {service.title}
          </h3>
          <p class="text-brand-muted text-sm leading-relaxed mb-4">{service.description}</p>
          <span class="text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
            Learn more
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
