---
interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  tags?: string[];
  category?: string;
}

const { title, description, href, image, tags = [], category } = Astro.props;
---

<a href={href} class="card-hover group flex flex-col h-full">
  {image && (
    <div class="overflow-hidden rounded-xl mb-4 aspect-video bg-brand-surface">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    </div>
  )}
  {!image && (
    <div class="rounded-xl mb-4 aspect-video bg-gradient-brand opacity-20 flex items-center justify-center">
      <svg class="w-12 h-12 text-brand-accent opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
      </svg>
    </div>
  )}

  {category && <span class="badge mb-3 self-start">{category}</span>}

  <h3 class="font-semibold text-lg font-heading mb-2 group-hover:text-brand-accent transition-colors">
    {title}
  </h3>
  <p class="text-brand-muted text-sm leading-relaxed line-clamp-3 flex-1">{description}</p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-4">
      {tags.map((tag) => (
        <span class="px-2 py-0.5 rounded-md text-xs bg-brand-surface text-brand-muted border border-brand-border">
          {tag}
        </span>
      ))}
    </div>
  )}

  <span class="mt-4 text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
    View project
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </span>
</a>
