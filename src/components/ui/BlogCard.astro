---
interface Props {
  title: string;
  description: string;
  href: string;
  publishedDate: string;
  category?: string;
  image?: string;
  readingTime?: string;
}

const { title, description, href, publishedDate, category, image, readingTime } = Astro.props;

const formattedDate = new Date(publishedDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});

const categoryColors: Record<string, string> = {
  Productivity: 'badge',
  Wellness:     'badge-purple',
  Mindfulness:  'badge-purple',
  Tech:         'badge',
};
const badgeClass = category ? (categoryColors[category] ?? 'badge') : 'badge';
---

<a href={href} class="card-hover group flex flex-col h-full">
  {image && (
    <div class="overflow-hidden rounded-xl mb-4 aspect-video">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
    </div>
  )}
  <div class="flex items-center gap-2 mb-3">
    {category && <span class={badgeClass}>{category}</span>}
    <span class="text-brand-muted text-xs">{formattedDate}</span>
    {readingTime && <span class="text-brand-muted text-xs">· {readingTime}</span>}
  </div>
  <h3 class="font-semibold text-brand-text font-heading mb-2 group-hover:text-brand-accent transition-colors line-clamp-2">
    {title}
  </h3>
  <p class="text-brand-muted text-sm leading-relaxed line-clamp-3 flex-1">{description}</p>
  <span class="mt-4 text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
    Read more
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
    </svg>
  </span>
</a>
