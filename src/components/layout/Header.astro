---
const navLinks = [
  { label: 'Home', href: '/' },
  {
    label: 'Services',
    href: '/services/',
    children: [
      { label: 'App Development', href: '/services/app-development/' },
      { label: 'Website Development', href: '/services/website-development/' },
      { label: 'Digital Marketing', href: '/services/digital-marketing/' },
      { label: 'UI/UX Design', href: '/services/ui-ux-design/' },
      { label: 'Data Science & Analytics', href: '/services/data-science/' },
      { label: 'Innovation Consulting', href: '/services/innovation-consulting/' },
    ],
  },
  {
    label: 'Products',
    href: '/products/',
    children: [
      { label: 'Digital Marketing Playbook', href: '/products/digital-marketing-playbook/' },
      { label: 'Pronova Productivity App', href: '/products/pronova-productivity-app/' },
      { label: 'Hosting & Maintenance', href: '/products/hosting-maintenance/' },
    ],
  },
  { label: 'Portfolio', href: '/portfolio/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 inset-x-0 z-50 bg-brand-primary/90 backdrop-blur-md border-b border-brand-border">
  <nav class="container flex items-center justify-between h-16 px-4 md:px-8 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Pronova Home">
      <img src="/images/logo.svg" alt="Pronova" class="h-8 w-auto" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
      <span class="gradient-text font-heading font-bold text-xl tracking-tight">Pronova</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {navLinks.map((link) => (
        <li class="relative group">
          {link.children ? (
            <>
              <button
                class:list={[
                  'btn-ghost flex items-center gap-1 text-sm',
                  currentPath.startsWith(link.href) && 'text-brand-accent',
                ]}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
                </svg>
              </button>
              <!-- Dropdown -->
              <ul
                class="absolute top-full left-0 mt-1 w-56 bg-brand-secondary border border-brand-border rounded-xl shadow-card
                       opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0
                       transition-all duration-200 p-1"
                role="list"
              >
                {link.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        'block px-3 py-2 rounded-lg text-sm text-brand-muted hover:text-brand-text hover:bg-brand-surface transition-colors',
                        currentPath === child.href && 'text-brand-accent bg-brand-surface',
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a
              href={link.href}
              class:list={[
                'btn-ghost text-sm',
                currentPath === link.href && 'text-brand-accent',
              ]}
            >
              {link.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA + Mobile Toggle -->
    <div class="flex items-center gap-3">
      <a href="/contact/" class="hidden md:inline-flex btn-primary text-sm py-2 px-4">
        Free Consultation
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2 rounded-lg text-brand-muted hover:text-brand-text hover:bg-brand-surface transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-brand-secondary border-t border-brand-border max-h-[80vh] overflow-y-auto"
  >
    <ul class="px-4 py-4 space-y-1" role="list">
      {navLinks.map((link) => (
        <li>
          {link.children ? (
            <details class="group/detail">
              <summary class="flex items-center justify-between px-3 py-2.5 rounded-lg text-brand-muted hover:text-brand-text hover:bg-brand-surface cursor-pointer list-none transition-colors">
                <span class="font-medium">{link.label}</span>
                <svg class="w-4 h-4 transition-transform group-open/detail:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
                </svg>
              </summary>
              <ul class="ml-3 mt-1 space-y-1 pl-3 border-l border-brand-border">
                {link.children.map((child) => (
                  <li>
                    <a href={child.href} class="block px-3 py-2 rounded-lg text-sm text-brand-muted hover:text-brand-text transition-colors">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a href={link.href} class="block px-3 py-2.5 rounded-lg font-medium text-brand-muted hover:text-brand-text hover:bg-brand-surface transition-colors">
              {link.label}
            </a>
          )}
        </li>
      ))}
      <li class="pt-2">
        <a href="/contact/" class="btn-primary w-full justify-center text-sm">Free Consultation</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconMenu?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
