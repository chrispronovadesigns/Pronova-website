---
const currentYear = new Date().getFullYear();

const services = [
  { label: 'App Development', href: '/services/app-development/' },
  { label: 'Website Development', href: '/services/website-development/' },
  { label: 'Digital Marketing', href: '/services/digital-marketing/' },
  { label: 'UI/UX Design', href: '/services/ui-ux-design/' },
  { label: 'Data Science & Analytics', href: '/services/data-science/' },
  { label: 'Innovation Consulting', href: '/services/innovation-consulting/' },
];

const products = [
  { label: 'Digital Marketing Playbook', href: '/products/digital-marketing-playbook/' },
  { label: 'Pronova Productivity App', href: '/products/pronova-productivity-app/' },
  { label: 'Hosting & Maintenance', href: '/products/hosting-maintenance/' },
];

const company = [
  { label: 'About', href: '/about/' },
  { label: 'Portfolio', href: '/portfolio/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/contact/' },
];

const social = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/company/pronova-designs',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/pronovadesignsbtx/',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/pronova_Designs/',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
];
---

<footer class="bg-brand-secondary border-t border-brand-border">
  <!-- Main Footer -->
  <div class="container max-w-7xl mx-auto px-4 md:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-2 space-y-4">
        <a href="/" class="flex items-center gap-2">
          <img src="/images/logo.svg" alt="Pronova" class="h-8 w-auto" onerror="this.style.display='none'" />
          <span class="gradient-text font-heading font-bold text-xl tracking-tight">Pronova</span>
        </a>
        <p class="text-brand-muted text-sm leading-relaxed max-w-xs">
          We build the digital products, websites, and marketing systems that turn business problems into measurable growth.
        </p>
        <div class="text-brand-muted text-sm space-y-1">
          <p>704 Paredes Line Rd, Brownsville, TX 78521</p>
          <p><a href="tel:9562540043" class="hover:text-brand-accent transition-colors">(956) 254-0043</a></p>
          <p><a href="mailto:chris@pronovadesigns.com" class="hover:text-brand-accent transition-colors">chris@pronovadesigns.com</a></p>
        </div>
        <!-- Social Links -->
        <div class="flex items-center gap-3 pt-2">
          {social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="p-2 rounded-lg text-brand-muted hover:text-brand-accent hover:bg-brand-surface transition-colors"
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Services -->
      <div class="space-y-4">
        <h3 class="font-semibold text-brand-text text-sm uppercase tracking-wider">Services</h3>
        <ul class="space-y-2" role="list">
          {services.map((link) => (
            <li>
              <a href={link.href} class="text-brand-muted text-sm hover:text-brand-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Products -->
      <div class="space-y-4">
        <h3 class="font-semibold text-brand-text text-sm uppercase tracking-wider">Products</h3>
        <ul class="space-y-2" role="list">
          {products.map((link) => (
            <li>
              <a href={link.href} class="text-brand-muted text-sm hover:text-brand-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="space-y-4">
        <h3 class="font-semibold text-brand-text text-sm uppercase tracking-wider">Company</h3>
        <ul class="space-y-2" role="list">
          {company.map((link) => (
            <li>
              <a href={link.href} class="text-brand-muted text-sm hover:text-brand-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-brand-border">
    <div class="container max-w-7xl mx-auto px-4 md:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-brand-muted text-sm">
        &copy; {currentYear} Pronova. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="/privacy-policy/" class="text-brand-muted text-xs hover:text-brand-text transition-colors">Privacy Policy</a>
        <a href="/terms/" class="text-brand-muted text-xs hover:text-brand-text transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
