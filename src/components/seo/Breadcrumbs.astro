---
import { buildBreadcrumbSchema } from '@/lib/seo/schema';

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;

const breadcrumbSchema = buildBreadcrumbSchema(items);
---

<!-- Breadcrumb Schema -->
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<!-- Visual Breadcrumbs -->
<nav aria-label="Breadcrumb" class={`text-sm ${className}`}>
  <ol class="flex items-center gap-2 flex-wrap">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && (
          <svg class="w-4 h-4 text-brand-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.url && index < items.length - 1 ? (
          <a 
            href={item.url} 
            class="text-brand-muted hover:text-brand-accent transition-colors"
          >
            {item.name}
          </a>
        ) : (
          <span class={index === items.length - 1 ? 'text-brand-text font-medium' : 'text-brand-muted'}>
            {item.name}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
