---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import ServicesGrid from '@/components/sections/ServicesGrid.astro';
import CTABanner from '@/components/sections/CTABanner.astro';
import PortfolioCard from '@/components/ui/PortfolioCard.astro';
import BlogCard from '@/components/ui/BlogCard.astro';

// Placeholder portfolio items — replace with TinaCMS data
const featuredProjects = [
  {
    title: 'popspot Mobile App',
    description: 'B2B mobile marketing SaaS providing location-specific advertising to drive business traffic.',
    href: '/portfolio/popspot-mobile-app/',
    tags: ['React Native', 'Node.js', 'SaaS'],
    category: 'Mobile App',
  },
];

// Placeholder blog posts — replace with TinaCMS data
const featuredPosts = [
  {
    title: 'How to Stay Productive as a Digital Nomad',
    description: 'Practical strategies for maintaining focus and output while working remotely from anywhere in the world.',
    href: '/blog/stay-productive-as-digital-nomad/',
    publishedDate: '2024-10-01',
    category: 'Productivity',
  },
  {
    title: 'Mindfulness Practices for Remote Workers',
    description: 'Simple daily routines that help remote professionals stay grounded, focused, and healthy.',
    href: '/blog/mindfulness-for-remote-workers/',
    publishedDate: '2024-09-15',
    category: 'Mindfulness',
  },
  {
    title: 'Top Tech Tools for the Modern Digital Nomad',
    description: 'The essential software stack every digital nomad needs to run a productive, location-independent business.',
    href: '/blog/top-tech-tools-digital-nomad/',
    publishedDate: '2024-09-01',
    category: 'Tech',
  },
];

const trustedTech = ['React', 'React Native', 'Next.js', 'Node.js', 'GraphQL', 'AWS', 'Firebase', 'MongoDB'];
---

<BaseLayout
  title="Pronova Designs"
  description="Custom digital solutions for startups and growing businesses in Brownsville, TX. App development, websites, digital marketing, UI/UX, data science, and more."
>
  <!-- Hero -->
  <Hero
    badge="Digital Product Development · Brownsville, TX"
    heading="Build Digital Products That "
    headingHighlight="Drive Real Growth"
    subheading="We design, develop, and deploy custom digital solutions — from mobile apps to marketing campaigns — that help businesses scale and succeed."
    primaryCTA={{ label: 'Start Your Project', href: '/contact/' }}
    secondaryCTA={{ label: 'See Our Work', href: '/portfolio/' }}
    showStats
  />

  <!-- Services -->
  <ServicesGrid />

  <!-- Why Pronova -->
  <section class="section bg-brand-secondary/50">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="badge mb-4">Why Pronova</span>
          <h2 class="text-3xl md:text-4xl font-bold font-heading mb-6">
            We Prioritize <span class="gradient-text">Real-World Results</span>
          </h2>
          <p class="text-brand-muted leading-relaxed mb-6">
            Since 2013, we've helped startups and small businesses across Texas and beyond build the
            digital products they need to compete. Our approach is business-first — every decision
            we make is grounded in what will actually move the needle for you.
          </p>
          <ul class="space-y-4">
            {[
              { icon: '🎯', title: 'Business-First Approach', desc: 'We align every technical decision with your goals.' },
              { icon: '🔩', title: 'Full-Stack Capability', desc: 'Strategy, design, development, and marketing — all in-house.' },
              { icon: '📍', title: 'Texas Roots, Global Reach', desc: 'Based in Brownsville, TX. Serving clients worldwide.' },
              { icon: '🔄', title: 'End-to-End Partnership', desc: 'We\'re with you from concept through post-launch growth.' },
            ].map((item) => (
              <li class="flex gap-4">
                <span class="text-2xl shrink-0">{item.icon}</span>
                <div>
                  <p class="font-semibold text-brand-text">{item.title}</p>
                  <p class="text-brand-muted text-sm">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
          <a href="/about/" class="btn-secondary mt-8 text-sm">Meet the Team</a>
        </div>

        <!-- Tech Stack -->
        <div class="card">
          <p class="text-brand-muted text-sm uppercase tracking-wider font-semibold mb-6">Our Core Tech Stack</p>
          <div class="flex flex-wrap gap-3">
            {trustedTech.map((tech) => (
              <span class="px-4 py-2 rounded-lg bg-brand-primary border border-brand-border text-brand-text text-sm font-medium">
                {tech}
              </span>
            ))}
          </div>
          <div class="mt-8 pt-6 border-t border-brand-border grid grid-cols-2 gap-4">
            <div>
              <p class="text-2xl font-bold gradient-text">10+</p>
              <p class="text-brand-muted text-xs mt-1">Years of Experience</p>
            </div>
            <div>
              <p class="text-2xl font-bold gradient-text">50+</p>
              <p class="text-brand-muted text-xs mt-1">Projects Delivered</p>
            </div>
            <div>
              <p class="text-2xl font-bold gradient-text">100%</p>
              <p class="text-brand-muted text-xs mt-1">Client Satisfaction</p>
            </div>
            <div>
              <p class="text-2xl font-bold gradient-text">24/7</p>
              <p class="text-brand-muted text-xs mt-1">Support Available</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  {featuredProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="flex items-end justify-between mb-12">
          <div>
            <span class="badge mb-4">Portfolio</span>
            <h2 class="text-3xl md:text-4xl font-bold font-heading">Featured Work</h2>
          </div>
          <a href="/portfolio/" class="btn-secondary text-sm hidden sm:inline-flex">View All Projects</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <PortfolioCard {...project} />
          ))}
        </div>
        <div class="mt-8 sm:hidden">
          <a href="/portfolio/" class="btn-secondary text-sm w-full justify-center">View All Projects</a>
        </div>
      </div>
    </section>
  )}

  <!-- Products Teaser -->
  <section class="section bg-brand-secondary/50">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="badge mb-4">Our Products</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4">Ready-Made Digital Solutions</h2>
        <p class="text-brand-muted">Off-the-shelf products designed to accelerate your digital growth.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            icon: '📘',
            title: 'Digital Marketing Playbook',
            description: 'The complete guide to growing your business online — strategy, tactics, and templates.',
            href: '/products/digital-marketing-playbook/',
          },
          {
            icon: '⚡',
            title: 'Pronova Productivity App',
            description: 'Stay focused and organized with our productivity tool built for digital nomads and remote teams.',
            href: '/products/pronova-productivity-app/',
          },
          {
            icon: '🖥️',
            title: 'Hosting & Maintenance',
            description: 'High-performance VPS hosting with proactive maintenance so your site never misses a beat.',
            href: '/products/hosting-maintenance/',
          },
        ].map((product) => (
          <a href={product.href} class="card-hover group">
            <div class="text-3xl mb-4">{product.icon}</div>
            <h3 class="font-semibold text-lg font-heading mb-2 group-hover:text-brand-accent transition-colors">
              {product.title}
            </h3>
            <p class="text-brand-muted text-sm leading-relaxed mb-4">{product.description}</p>
            <span class="text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Learn more
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Preview -->
  {featuredPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="flex items-end justify-between mb-12">
          <div>
            <span class="badge mb-4">Digital Nomad Blog</span>
            <h2 class="text-3xl md:text-4xl font-bold font-heading">Latest Insights</h2>
            <p class="text-brand-muted mt-2">Productivity · Wellness · Mindfulness · Tech</p>
          </div>
          <a href="/blog/" class="btn-secondary text-sm hidden sm:inline-flex">All Articles</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredPosts.map((post) => (
            <BlogCard {...post} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTABanner />
</BaseLayout>
