---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import ServicesGrid from '@/components/sections/ServicesGrid.astro';
import CTABanner from '@/components/sections/CTABanner.astro';
import PortfolioCard from '@/components/ui/PortfolioCard.astro';
import BlogCard from '@/components/ui/BlogCard.astro';

const featuredProjects = [
  {
    title: 'Hexatronic field technician app',
    description: 'Multi-platform mobile and web application with real-time geo-location tracking, 2FA, and an admin dashboard for dispatchers.',
    href: '/portfolio/hexatronic/',
    tags: ['React Native', 'Node.js', 'Geo-Location'],
    category: 'Mobile App',
  },
  {
    title: 'Rosas Medical Clinic',
    description: 'Full SEO overhaul and digital marketing system that generated 2,847 new patient leads in six months.',
    href: '/portfolio/rosas-medical-clinic/',
    tags: ['SEO', 'Google Ads', 'SMS'],
    category: 'Digital Marketing',
  },
  {
    title: 'San Benito Housing Authority',
    description: '20-page modernized website with mobile-responsive design, WordPress CMS, and VPS cloud hosting — delivered in four weeks.',
    href: '/portfolio/san-benito-housing-authority/',
    tags: ['WordPress', 'UI/UX', 'Hosting'],
    category: 'Website',
  },
];

const featuredPosts = [
  {
    title: 'Why does Google Search Console hide keyword click data?',
    description: 'The real reasons behind GSC data discrepancies — and what you can do about it.',
    href: '/blog/why-gsc-hides-keyword-data/',
    publishedDate: '2025-02-15',
    category: 'SEO',
  },
];

const trustedTech = ['React', 'React Native', 'Node.js', 'Astro', 'Next.js', 'AWS', 'GraphQL', 'Python'];

const results = [
  { value: '147K+', label: 'Leads generated for clients' },
  { value: '47', label: 'Businesses put on page one' },
  { value: '$8.7M', label: 'Client revenue tracked to our work' },
  { value: '72 days', label: 'Average time to page one' },
];
---

<BaseLayout
  title="Pronova — Apps. Websites. Marketing."
  description="We build the digital products, websites, and marketing systems that turn business problems into measurable growth. Based in Texas."
>
  <!-- Hero -->
  <Hero
    badge="Technology studio — Brownsville, TX"
    heading="You know the problem. We create the "
    headingHighlight="solution."
    descriptor="Apps. Websites. Marketing."
    subheading="We build the entire pipeline — from first click to closed deal. Premium design, advanced engineering, and data intelligence that delivers measurable business outcomes."
    primaryCTA={{ label: 'Start your project', href: '/contact/' }}
    secondaryCTA={{ label: 'See our work', href: '/portfolio/' }}
    showStats
  />

  <!-- Services -->
  <ServicesGrid />

  <!-- Results -->
  <section class="section-sm bg-brand-secondary/50">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {results.map((r) => (
          <div>
            <p class="text-3xl md:text-4xl font-bold gradient-text font-heading">{r.value}</p>
            <p class="text-brand-muted text-sm mt-2">{r.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Pronova -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="badge mb-4">Why Pronova</span>
          <h2 class="text-3xl md:text-4xl font-bold font-heading mb-6">
            The gap between your goals and your <span class="gradient-text">digital presence</span> is costing you money
          </h2>
          <p class="text-brand-muted leading-relaxed mb-6">
            Businesses with great products and real market demand get outpaced by competitors with better digital infrastructure. Not because those competitors are smarter — but because they've invested in the right technology at the right time. We build the foundation and everything on top of it.
          </p>
          <ul class="space-y-4">
            {[
              { title: 'Business-first approach', desc: 'Every technical decision is grounded in what will actually move the needle for you.' },
              { title: 'Full-stack capability', desc: 'Strategy, design, development, and marketing — all in-house, all connected.' },
              { title: 'Texas roots, global reach', desc: 'Based in the Rio Grande Valley. You can sit across from us at a coffee shop and look at your results.' },
              { title: 'Month-to-month everything', desc: 'No long-term contracts. We earn your business every single month.' },
            ].map((item) => (
              <li class="flex gap-4">
                <span class="shrink-0 mt-1 w-5 h-5 rounded-full bg-brand-accent/20 flex items-center justify-center">
                  <span class="w-2 h-2 rounded-full bg-brand-accent"></span>
                </span>
                <div>
                  <p class="font-semibold text-brand-text">{item.title}</p>
                  <p class="text-brand-muted text-sm">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
          <a href="/about/" class="btn-secondary mt-8 text-sm">Learn more about us</a>
        </div>

        <!-- Tech Stack -->
        <div class="card">
          <p class="text-brand-muted text-sm uppercase tracking-[0.08em] font-semibold mb-6">Core tech stack</p>
          <div class="flex flex-wrap gap-3">
            {trustedTech.map((tech) => (
              <span class="px-4 py-2 rounded-lg bg-brand-primary border border-brand-border text-brand-text text-sm font-medium">
                {tech}
              </span>
            ))}
          </div>
          <div class="mt-8 pt-6 border-t border-brand-border grid grid-cols-2 gap-4">
            <div>
              <p class="text-2xl font-bold gradient-text">15+</p>
              <p class="text-brand-muted text-xs mt-1">Years building products</p>
            </div>
            <div>
              <p class="text-2xl font-bold gradient-text">50+</p>
              <p class="text-brand-muted text-xs mt-1">Projects delivered</p>
            </div>
            <div>
              <p class="text-2xl font-bold gradient-text">3</p>
              <p class="text-brand-muted text-xs mt-1">Integrated divisions</p>
            </div>
            <div>
              <p class="text-2xl font-bold gradient-text">0</p>
              <p class="text-brand-muted text-xs mt-1">Long-term contracts</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  {featuredProjects.length > 0 && (
    <section class="section bg-brand-secondary/50">
      <div class="container">
        <div class="flex items-end justify-between mb-12">
          <div>
            <span class="badge mb-4">Portfolio</span>
            <h2 class="text-3xl md:text-4xl font-bold font-heading">The results tell the story</h2>
          </div>
          <a href="/portfolio/" class="btn-secondary text-sm hidden sm:inline-flex">View all projects</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => (
            <PortfolioCard {...project} />
          ))}
        </div>
        <div class="mt-8 sm:hidden">
          <a href="/portfolio/" class="btn-secondary text-sm w-full justify-center">View all projects</a>
        </div>
      </div>
    </section>
  )}

  <!-- Products Teaser -->
  <section class="section">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="badge mb-4">Products</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4">Ready-made digital solutions</h2>
        <p class="text-brand-muted">Off-the-shelf products designed to accelerate your digital growth.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>`,
            title: 'Digital marketing playbook',
            description: 'The complete guide to growing your business online — strategy, tactics, and templates you can execute yourself.',
            href: '/products/digital-marketing-playbook/',
          },
          {
            icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
            title: 'Pronova productivity app',
            description: 'Stay focused and organized with our productivity tool built for remote teams and growing businesses.',
            href: '/products/pronova-productivity-app/',
          },
          {
            icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" /></svg>`,
            title: 'Hosting and maintenance',
            description: 'High-performance VPS hosting with proactive maintenance so your site never misses a beat. Month-to-month.',
            href: '/products/hosting-maintenance/',
          },
        ].map((product) => (
          <a href={product.href} class="card-hover group">
            <div class="mb-4 text-brand-accent" set:html={product.icon} />
            <h3 class="font-semibold text-lg font-heading mb-2 group-hover:text-brand-accent transition-colors">
              {product.title}
            </h3>
            <p class="text-brand-muted text-sm leading-relaxed mb-4">{product.description}</p>
            <span class="text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Learn more
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Preview -->
  {featuredPosts.length > 0 && (
    <section class="section bg-brand-secondary/50">
      <div class="container">
        <div class="flex items-end justify-between mb-12">
          <div>
            <span class="badge mb-4">Blog</span>
            <h2 class="text-3xl md:text-4xl font-bold font-heading">Latest insights</h2>
          </div>
          <a href="/blog/" class="btn-secondary text-sm hidden sm:inline-flex">All articles</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {featuredPosts.map((post) => (
            <BlogCard {...post} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTABanner />
</BaseLayout>
