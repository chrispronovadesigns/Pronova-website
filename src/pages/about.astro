---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/sections/CTABanner.astro';

const team = [
  {
    name: 'Chris',
    role: 'Co-Founder & CEO',
    bio: 'Visionary leader with a passion for digital innovation. Chris brings strategic insight and technical expertise to every project, ensuring Pronova Designs delivers solutions that create real-world impact.',
    photo: '/images/team/chris.jpg',
    href: '/about/chris/',
  },
  {
    name: 'Mig',
    role: 'Co-Founder & CTO',
    bio: 'Full-stack architect and creative problem-solver. Mig leads the technical development of all Pronova products and client solutions, championing clean code and cutting-edge frameworks.',
    photo: '/images/team/mig.jpg',
    href: '/about/mig/',
  },
];

const values = [
  { title: 'Business-first thinking', desc: 'Every decision is grounded in your real-world goals — not just cool tech.' },
  { title: 'Genuine partnership', desc: 'We embed ourselves in your success for the long haul, not just the project.' },
  { title: 'Month-to-month everything', desc: 'No long-term contracts. We earn your business every single month.' },
  { title: 'Craftsmanship', desc: 'We obsess over the details — design, performance, and code quality.' },
  { title: 'Community impact', desc: 'Proud to grow local businesses in the Rio Grande Valley and beyond.' },
  { title: 'You own everything', desc: 'The code, the design, the server configuration — it is all yours. Zero lock-in.' },
];
---

<BaseLayout
  title="About | Pronova"
  description="A technology studio that builds the entire pipeline — from first click to closed deal. Based in Texas, building things that work."
>
  <!-- Page Hero -->
  <section class="relative section pt-32 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl" />
    </div>
    <div class="container text-center max-w-3xl mx-auto relative z-10">
      <span class="badge mb-4">About Pronova</span>
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6">
        Built by builders, <span class="gradient-text">for builders</span>
      </h1>
      <p class="text-brand-muted text-lg leading-relaxed">
        Pronova is a technology studio that brings together app development, website development, and digital marketing under one roof. When these work in isolation, you get disconnected tools. When they work together — designed by the same team, built on the same strategy — you get a pipeline that turns attention into revenue.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="section-sm">
    <div class="container max-w-4xl mx-auto">
      <div class="card space-y-4 text-brand-muted leading-relaxed">
        <p>
          We started Pronova because we kept seeing the same problem: businesses with great products and real market demand getting outpaced by competitors with better digital infrastructure. Not because those competitors were smarter — but because they had invested in the right technology at the right time.
        </p>
        <p>
          Over 15 years later, we have generated over 147,000 leads for clients, put 47 businesses on page one of Google, and tracked over $8.7 million in client revenue tied directly to our work. We are based in Texas and we build things that work.
        </p>
        <p>
          Our team combines deep technical expertise with a strategic business mindset. The biggest gap in digital development is not technical — it is the translation layer between what a business owner needs and what a developer builds. We are obsessive about closing that gap.
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-16">
        <span class="badge mb-4">The team</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading">Meet the co-founders</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        {team.map((member) => (
          <a href={member.href} class="card-hover group text-center">
            <div class="w-28 h-28 rounded-full bg-gradient-brand mx-auto mb-4 overflow-hidden flex items-center justify-center">
              <img
                src={member.photo}
                alt={member.name}
                class="w-full h-full object-cover"
                onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
              />
              <span class="text-white text-3xl font-bold hidden w-full h-full items-center justify-center">
                {member.name.charAt(0)}
              </span>
            </div>
            <h3 class="font-bold text-xl font-heading group-hover:text-brand-accent transition-colors">{member.name}</h3>
            <p class="text-brand-accent text-sm font-medium mb-3">{member.role}</p>
            <p class="text-brand-muted text-sm leading-relaxed">{member.bio}</p>
            <span class="mt-4 text-brand-accent text-sm font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Read full bio →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section bg-brand-secondary/50">
    <div class="container">
      <div class="text-center mb-16">
        <span class="badge mb-4">Our values</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading">What we stand for</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {values.map((value) => (
          <div class="card">
            <div class="mb-3 w-5 h-5 rounded-full bg-brand-accent/20 flex items-center justify-center"><span class="w-2 h-2 rounded-full bg-brand-accent"></span></div>
            <h3 class="font-semibold text-lg font-heading mb-2">{value.title}</h3>
            <p class="text-brand-muted text-sm leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Let's build something together"
    subheading="Ready to partner with a team that is genuinely invested in your success?"
  />
</BaseLayout>
