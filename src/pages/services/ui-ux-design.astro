---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/sections/CTABanner.astro';

const deliverables = [
  { icon: '🗺️', title: 'User Research & Journey Mapping', desc: 'Understanding your users deeply to design experiences they love.' },
  { icon: '🖊️', title: 'Wireframing & Prototyping', desc: 'Rapid iteration from concept to interactive prototype before a line of code is written.' },
  { icon: '🎨', title: 'Visual Design', desc: 'Polished, on-brand UI that balances beauty with usability.' },
  { icon: '📐', title: 'Design Systems', desc: 'Scalable component libraries that keep your product consistent as it grows.' },
  { icon: '♿', title: 'Accessibility (WCAG)', desc: 'Inclusive design practices so your product works for everyone.' },
  { icon: '🧪', title: 'Usability Testing', desc: 'Real user feedback validated before launch to eliminate friction.' },
];
---

<BaseLayout
  title="UI/UX Design Services | Pronova Designs"
  description="Expert UI/UX design services in Brownsville, TX. User research, wireframing, prototyping, and visual design for apps and websites."
>
  <section class="section pt-32 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-96 h-96 bg-brand-highlight/10 rounded-full blur-3xl pointer-events-none" />
    <div class="container max-w-4xl mx-auto">
      <a href="/services/" class="text-brand-muted text-sm hover:text-brand-accent transition-colors inline-flex items-center gap-1 mb-8">← All Services</a>
      <span class="badge mb-4">UI/UX Design</span>
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6">
        Design That <span class="gradient-text">Delights and Converts</span>
      </h1>
      <p class="text-brand-muted text-lg leading-relaxed max-w-2xl mb-8">
        Excellent design isn't just about looks — it's about creating an experience.
        We combine technical depth and design artistry to build products users love.
      </p>
      <a href="/contact/" class="btn-primary">Start a Design Project</a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {deliverables.map((d) => (
          <div class="card">
            <div class="text-3xl mb-3">{d.icon}</div>
            <h3 class="font-semibold text-lg font-heading mb-2">{d.title}</h3>
            <p class="text-brand-muted text-sm leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner heading="Let's Design Something Beautiful" subheading="Great design starts with a conversation." />
</BaseLayout>
