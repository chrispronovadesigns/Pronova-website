---
import ServiceLayout from '@/layouts/ServiceLayout.astro';

const process = [
  { title: 'User research and personas', desc: 'Real data about your users, not assumptions. Who they are, what they want, what frustrates them.' },
  { title: 'Information architecture', desc: 'The structural blueprint that determines how content is organized and how users navigate through it.' },
  { title: 'Wireframes', desc: 'Low-fidelity layouts that let us test structure and flow before anyone worries about visual polish.' },
  { title: 'Visual design', desc: 'The interface comes to life with your brand identity, purposeful color systems, typography that aids readability, and visual hierarchy that guides the eye.' },
  { title: 'Interactive prototyping', desc: 'A clickable version of the product that lets you test the experience before development begins. This is where we catch problems that cost 10x more to fix in code.' },
  { title: 'Usability testing', desc: 'Real users interact with the prototype while we watch, measure, and refine.' },
];
---

<ServiceLayout
  title="UI/UX design | Pronova"
  description="Design that works before it looks good. User research, wireframing, visual design, prototyping, and usability testing for apps and websites."
  badge="UI/UX design"
  heading="Design that works before it "
  headingHighlight="looks good."
  subheading="Beautiful design that nobody can figure out how to use is just expensive art. We design digital experiences that feel natural to your users — and drive the specific actions your business needs."
  ctaHeading="Let's design something that actually works"
  ctaSubheading="We start with understanding your users and your business goals, then build interfaces that serve both."
>
  <!-- The Problem -->
  <section class="section">
    <div class="container max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-6">The real cost of bad design</h2>
      <div class="text-brand-muted leading-relaxed space-y-4">
        <p>Most businesses think of design as the visual layer — colors, fonts, layouts. That is a piece of it. But the design decisions that actually affect your revenue are invisible to most people: where buttons are placed, how forms are structured, what information appears first, how navigation flows from one screen to the next.</p>
        <p><strong class="text-brand-text">88% of users</strong> will not return to a site after a bad experience. <strong class="text-brand-text">70% of online businesses</strong> fail because of poor usability. Every confusing menu, every buried call to action, every extra click between your user and their goal is revenue walking out the door.</p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section bg-brand-secondary/50">
    <div class="container max-w-4xl mx-auto">
      <span class="badge mb-4">Our process</span>
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4">Function first, then beauty</h2>
      <p class="text-brand-muted leading-relaxed mb-12">We do not start with mood boards or color palettes. We start with questions: Who is using this? What do they need to accomplish? What is getting in their way right now?</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {process.map((step, i) => (
          <div class="card flex gap-4">
            <span class="text-lg font-bold gradient-text font-heading shrink-0">0{i + 1}</span>
            <div>
              <h3 class="font-semibold font-heading mb-1">{step.title}</h3>
              <p class="text-brand-muted text-sm leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
