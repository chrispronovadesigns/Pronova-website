---
import ServiceLayout from '@/layouts/ServiceLayout.astro';

const offerings = [
  { title: 'Concept validation', desc: 'Before you spend six figures building something, we help you validate the concept — market fit, technical feasibility, and ROI justification.' },
  { title: 'Tech stack audit', desc: 'We audit your current technology to find weak links costing you money, then recommend specific improvements with projected impact.' },
  { title: 'Phased digital strategy', desc: 'A sequenced roadmap that prioritizes the highest-impact investments first — so you are not trying to do everything at once.' },
  { title: 'Product roadmapping', desc: 'From MVP to market — phased development plans that minimize risk and maximize learning at every stage.' },
  { title: 'Architecture review', desc: 'Deep technical assessment of your existing systems with a clear plan for modernization and scaling.' },
  { title: 'Fractional CTO', desc: 'On-demand technical leadership for startups and businesses without an in-house CTO. Strategy, vendor evaluation, team hiring.' },
];
---

<ServiceLayout
  title="Innovation consulting | Pronova"
  description="We help businesses figure out which technology investments will actually move the needle — and then we build them. Concept validation, tech audits, and digital strategy."
  badge="Innovation consulting"
  heading="When you know things need to change but you are not sure what to "
  headingHighlight="build."
  subheading="Technology decisions are expensive and hard to reverse. We help you evaluate opportunities, validate concepts, define technical requirements, and build a roadmap that connects your business goals to specific, buildable solutions."
  ctaHeading="Let's figure out what is worth building"
  ctaSubheading="We are not theoretical consultants — we are the people who will actually build the thing once the strategy is right."
>
  <!-- The Problem -->
  <section class="section">
    <div class="container max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-6">The problem we keep seeing</h2>
      <div class="text-brand-muted leading-relaxed space-y-4">
        <p>Businesses — especially small and mid-size ones — are being sold technology they do not need by people who will not be around to fix it when things go sideways. A $40,000 app that nobody uses. A "digital transformation" initiative that produces a deck of slides and nothing else. An AI integration that sounds impressive in the pitch meeting but creates more work, not less.</p>
        <p>The issue is not that these businesses lack ambition or budget. It is that they do not have a trusted technical partner who will tell them the truth: <strong class="text-brand-text">what is worth building, what is not, and what order to do things in.</strong></p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="section bg-brand-secondary/50">
    <div class="container max-w-4xl mx-auto">
      <span class="badge mb-4">What we deliver</span>
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-12">Advisors who also build</h2>
      <p class="text-brand-muted leading-relaxed mb-8">What makes this different from typical consulting is simple: we are not just advisors. We are builders. If the strategy calls for an app, a website, or a marketing system, we build it — with the same team that helped define the strategy.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {offerings.map((o, i) => (
          <div class="card flex gap-4">
            <span class="text-lg font-bold gradient-text font-heading shrink-0">0{i + 1}</span>
            <div>
              <h3 class="font-semibold font-heading mb-1">{o.title}</h3>
              <p class="text-brand-muted text-sm leading-relaxed">{o.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
