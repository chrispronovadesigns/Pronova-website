---
import ServiceLayout from '@/layouts/ServiceLayout.astro';

const offerings = [
  { title: 'Data extraction and integration', desc: 'We connect your scattered data sources into a unified system. CRMs, marketing platforms, sales tools, financial systems — all feeding into one place.' },
  { title: 'Automated reporting and dashboards', desc: 'Custom dashboards that show you exactly what matters, updated in real time. No more waiting for someone to pull a report.' },
  { title: 'Advanced analytics', desc: 'Trend analysis, customer segmentation, predictive modeling, and revenue attribution. We help you see what is coming, not just what already happened.' },
  { title: 'Machine learning applications', desc: 'When your data is complex enough to benefit from it, we build models that identify patterns and opportunities a human would miss.' },
  { title: 'Database development and management', desc: 'Proper data architecture that scales with your business and does not require a PhD to maintain.' },
  { title: 'Analytics integration', desc: 'GA4, Mixpanel, Segment — full analytics stack setup, configuration, and ongoing management.' },
];
---

<ServiceLayout
  title="Data science and analytics | Pronova"
  description="We turn your raw data into clear insights and automated systems that drive smarter decisions. Data extraction, dashboards, predictive analytics, and machine learning."
  badge="Data science and analytics"
  heading="Your data is talking — you just need someone who speaks the "
  headingHighlight="language."
  subheading="Every business is sitting on data that could be driving better decisions — but it is scattered across spreadsheets, databases, CRMs, and platforms that do not talk to each other. We fix that."
  ctaHeading="Let's figure out what your data is telling you"
  ctaSubheading="Every data project starts with understanding what decisions you need to make — then we build backward to the infrastructure that supports those decisions."
>
  <!-- The Problem -->
  <section class="section">
    <div class="container max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-6">The data problem nobody wants to admit</h2>
      <div class="text-brand-muted leading-relaxed space-y-4">
        <p>You have got data everywhere. Google Analytics, your CRM, your POS system, email platforms, social media, spreadsheets your team maintains manually. It is all there. But it is not connected, it is not clean, and it is definitely not telling you anything useful in its current form.</p>
        <p>Most businesses operate on a mix of instinct and incomplete reports. They know roughly what is working and roughly what is not, but they can not pinpoint exactly where revenue is leaking, which campaigns are actually profitable, or what their customers are about to do next.</p>
      </div>
    </div>
  </section>

  <!-- What We Build -->
  <section class="section bg-brand-secondary/50">
    <div class="container max-w-4xl mx-auto">
      <span class="badge mb-4">What we build</span>
      <h2 class="text-3xl md:text-4xl font-bold font-heading mb-12">From raw data to actionable intelligence</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {offerings.map((o, i) => (
          <div class="card flex gap-4">
            <span class="text-lg font-bold gradient-text font-heading shrink-0">0{i + 1}</span>
            <div>
              <h3 class="font-semibold font-heading mb-1">{o.title}</h3>
              <p class="text-brand-muted text-sm leading-relaxed">{o.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
