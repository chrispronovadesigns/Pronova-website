---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/sections/CTABanner.astro';

const features = [
  { icon: '🍎', title: 'iOS App Development', desc: 'Native Swift and SwiftUI apps for iPhone and iPad with App Store deployment.' },
  { icon: '🤖', title: 'Android App Development', desc: 'Native Kotlin apps optimized for the full Android ecosystem.' },
  { icon: '⚛️', title: 'Cross-Platform (React Native)', desc: 'One codebase, both platforms — faster delivery without sacrificing quality.' },
  { icon: '🌐', title: 'Web App Development', desc: 'Progressive web apps and full-stack solutions with React, Next.js, and Node.js.' },
  { icon: '🔗', title: 'API & Backend Development', desc: 'Robust REST and GraphQL APIs, cloud infrastructure, and database design.' },
  { icon: '☁️', title: 'Cloud & DevOps', desc: 'AWS, Firebase, and CI/CD pipelines that keep your app fast, secure, and scalable.' },
];

const techStack = ['React Native', 'React', 'Next.js', 'Node.js', 'GraphQL', 'AWS', 'Firebase', 'Swift', 'Kotlin', 'MongoDB', 'PostgreSQL'];
---

<BaseLayout
  title="App Development Services | Pronova Designs"
  description="Custom mobile and web app development in Texas. iOS, Android, and cross-platform apps built by experienced developers in Brownsville, TX."
>
  <!-- Hero -->
  <section class="section pt-32 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true" />
    <div class="container max-w-4xl mx-auto">
      <a href="/services/" class="text-brand-muted text-sm hover:text-brand-accent transition-colors inline-flex items-center gap-1 mb-8">
        ← All Services
      </a>
      <span class="badge mb-4">App Development</span>
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6">
        Custom Apps That <span class="gradient-text">Move Your Business Forward</span>
      </h1>
      <p class="text-brand-muted text-lg leading-relaxed max-w-2xl mb-8">
        We craft bespoke mobile and web applications that combine cutting-edge technology,
        elegant design, and strategic business insight. Whether you need an iOS app, an Android
        app, or a full-stack web application — we build it right.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/contact/" class="btn-primary">Start Your App Project</a>
        <a href="/portfolio/" class="btn-secondary">View App Portfolio</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold font-heading mb-4">Full-Spectrum App Development</h2>
        <p class="text-brand-muted max-w-xl mx-auto">From mobile-first to enterprise web applications — we cover the full stack.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f) => (
          <div class="card">
            <div class="text-3xl mb-3">{f.icon}</div>
            <h3 class="font-semibold text-lg font-heading mb-2">{f.title}</h3>
            <p class="text-brand-muted text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="section-sm bg-brand-secondary/50">
    <div class="container text-center">
      <p class="text-brand-muted text-sm uppercase tracking-wider font-semibold mb-6">Technologies We Use</p>
      <div class="flex flex-wrap justify-center gap-3">
        {techStack.map((tech) => (
          <span class="px-4 py-2 rounded-lg bg-brand-primary border border-brand-border text-brand-text text-sm font-medium">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Ready to Build Your App?"
    subheading="Get a free consultation and project estimate from our team."
    primaryCTA={{ label: 'Get a Free Consultation', href: '/contact/' }}
    secondaryCTA={{ label: 'View Our Work', href: '/portfolio/' }}
  />
</BaseLayout>
