---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServicesGrid from '@/components/sections/ServicesGrid.astro';
import CTABanner from '@/components/sections/CTABanner.astro';
---

<BaseLayout
  title="Digital Product Development Services | Pronova Designs"
  description="Explore Pronova Designs' full suite of digital services: app development, website development, digital marketing, UI/UX design, data science, and innovation consulting."
>
  <section class="section pt-32">
    <div class="container text-center max-w-2xl mx-auto">
      <span class="badge mb-4">Our Services</span>
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">
        End-to-End Digital <span class="gradient-text">Solutions</span>
      </h1>
      <p class="text-brand-muted text-lg leading-relaxed">
        From first idea to market launch and beyond — we cover every stage of your digital journey
        with specialized expertise.
      </p>
    </div>
  </section>

  <ServicesGrid />

  <!-- Process -->
  <section class="section bg-brand-secondary/50">
    <div class="container">
      <div class="text-center mb-16">
        <span class="badge mb-4">Our Process</span>
        <h2 class="text-3xl md:text-4xl font-bold font-heading">How We Work</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: '01', title: 'Discover', desc: 'We dive deep into your goals, audience, and competitive landscape.' },
          { step: '02', title: 'Design', desc: 'Strategy and UI/UX design that prioritizes user experience and business outcomes.' },
          { step: '03', title: 'Build', desc: 'Agile development with regular updates so you\'re always in the loop.' },
          { step: '04', title: 'Grow', desc: 'Post-launch support, marketing, and data-driven iteration for sustained growth.' },
        ].map((phase) => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-gradient-brand flex items-center justify-center text-white font-bold text-sm mx-auto mb-4">
              {phase.step}
            </div>
            <h3 class="font-semibold text-lg font-heading mb-2">{phase.title}</h3>
            <p class="text-brand-muted text-sm leading-relaxed">{phase.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
