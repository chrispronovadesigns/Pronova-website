---
import BaseLayout from '@/layouts/BaseLayout.astro';

const contactMethods = [
  {
    label: 'Email',
    value: 'chris@pronovadesigns.com',
    href: 'mailto:chris@pronovadesigns.com',
  },
  {
    label: 'Phone',
    value: '(956) 254-0043',
    href: 'tel:9562540043',
  },
  {
    label: 'Location',
    value: '704 Paredes Line Rd, Brownsville, TX 78521',
    href: 'https://maps.app.goo.gl/SAviVsAxBc4f2NmD6',
  },
];
---

<BaseLayout
  title="Contact | Pronova"
  description="Get in touch with Pronova for a free consultation. We help businesses build custom digital solutions — apps, websites, and marketing systems."
>
  <section class="section pt-32">
    <div class="container max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="badge mb-4">Contact</span>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">
          Every project starts with a <span class="gradient-text">conversation</span>
        </h1>
        <p class="text-brand-muted text-lg">
          Tell us about your project and we will get back to you with a free consultation. No pitch, no obligation.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Form -->
        <div class="lg:col-span-3 card">
          <h2 class="font-semibold text-xl font-heading mb-6">Send us a message</h2>
          <form
            name="contact"
            method="POST"
            action="/contact/success/"
            class="space-y-5"
            data-netlify="true"
            data-netlify-honeypot="_gotcha"
          >
            <!-- Honeypot field — hidden from real users, traps bots -->
            <div class="absolute opacity-0 top-0 left-0 h-0 w-0 -z-10 overflow-hidden" aria-hidden="true">
              <label>Do not fill this out
                <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
              </label>
            </div>
            <!-- Anti-spam timestamp -->
            <input type="hidden" name="_form_loaded" value="" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-brand-muted mb-1.5" for="first-name">First Name</label>
                <input type="text" id="first-name" name="first_name" class="input" placeholder="John" required maxlength="100" autocomplete="given-name" />
              </div>
              <div>
                <label class="block text-sm font-medium text-brand-muted mb-1.5" for="last-name">Last Name</label>
                <input type="text" id="last-name" name="last_name" class="input" placeholder="Doe" required maxlength="100" autocomplete="family-name" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-brand-muted mb-1.5" for="email">Email Address</label>
              <input type="email" id="email" name="email" class="input" placeholder="john@company.com" required maxlength="254" autocomplete="email" />
            </div>
            <div>
              <label class="block text-sm font-medium text-brand-muted mb-1.5" for="phone">Phone (optional)</label>
              <input type="tel" id="phone" name="phone" class="input" placeholder="+1 (555) 000-0000" maxlength="20" autocomplete="tel" />
            </div>
            <div>
              <label class="block text-sm font-medium text-brand-muted mb-1.5" for="service">Service Interested In</label>
              <select id="service" name="service" class="input">
                <option value="">Select a service...</option>
                <option value="app-development">App Development</option>
                <option value="website-development">Website Development</option>
                <option value="digital-marketing">Digital Marketing</option>
                <option value="ui-ux-design">UI/UX Design</option>
                <option value="data-science">Data Science & Analytics</option>
                <option value="innovation-consulting">Innovation Consulting</option>
                <option value="hosting-maintenance">Hosting & Maintenance</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-brand-muted mb-1.5" for="budget">Estimated Budget</label>
              <select id="budget" name="budget" class="input">
                <option value="">Select a range...</option>
                <option value="under-5k">Under $5,000</option>
                <option value="5k-15k">$5,000 – $15,000</option>
                <option value="15k-50k">$15,000 – $50,000</option>
                <option value="50k-plus">$50,000+</option>
                <option value="not-sure">Not Sure Yet</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-brand-muted mb-1.5" for="message">Tell Us About Your Project</label>
              <textarea id="message" name="message" rows="4" class="textarea" placeholder="Describe your project goals, timeline, and any details that would help us understand your needs..." required maxlength="5000"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full justify-center text-base py-3.5">
              Send Message
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="card space-y-6">
            <h2 class="font-semibold text-xl font-heading">Get in touch</h2>
            {contactMethods.map((method) => (
              <a href={method.href} class="flex items-start gap-4 group" target={method.href.startsWith('http') ? '_blank' : undefined} rel={method.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                <span class="shrink-0 mt-1 w-5 h-5 rounded-full bg-brand-accent/20 flex items-center justify-center"><span class="w-2 h-2 rounded-full bg-brand-accent"></span></span>
                <div>
                  <p class="text-brand-muted text-xs font-medium uppercase tracking-wider mb-0.5">{method.label}</p>
                  <p class="text-brand-text font-medium group-hover:text-brand-accent transition-colors">{method.value}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="card">
            <h3 class="font-semibold font-heading mb-3">Free consultation includes</h3>
            <ul class="space-y-2.5">
              {[
                'Project scope review',
                'Technology recommendations',
                'Timeline estimate',
                'Budget range discussion',
                'No-obligation proposal',
              ].map((item) => (
                <li class="flex items-center gap-2.5 text-sm text-brand-muted">
                  <svg class="w-4 h-4 text-brand-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="card text-center">
            <p class="text-brand-muted text-sm mb-1">Typical response time</p>
            <p class="text-2xl font-bold gradient-text">Under 24 Hours</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const formLoaded = document.querySelector<HTMLInputElement>('input[name="_form_loaded"]');
  if (formLoaded) {
    formLoaded.value = Date.now().toString();
  }
</script>
