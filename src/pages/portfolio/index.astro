---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PortfolioCard from '@/components/ui/PortfolioCard.astro';
import CTABanner from '@/components/sections/CTABanner.astro';

let projects: any[] = [];
try {
  projects = (await getCollection('portfolio'))
    .sort((a: any, b: any) => {
      if (a.data.featured && !b.data.featured) return -1;
      if (!a.data.featured && b.data.featured) return 1;
      if (a.data.completedDate && b.data.completedDate) {
        return new Date(b.data.completedDate).getTime() - new Date(a.data.completedDate).getTime();
      }
      return 0;
    });
} catch {
  projects = [];
}

const categories = ['All', 'Mobile App', 'Web App', 'Website', 'Digital Marketing', 'UI/UX', 'Data Science'];
---

<BaseLayout
  title="Portfolio | Pronova"
  description="Custom digital solutions — mobile apps, web apps, websites, and digital marketing campaigns. The results tell the story."
>
  <section class="section pt-32">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <span class="badge mb-4">Our work</span>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">
          The results tell the <span class="gradient-text">story</span>
        </h1>
        <p class="text-brand-muted text-lg">
          From mobile apps to full marketing ecosystems — every project represents a real business problem solved.
        </p>
      </div>

      <!-- Category Filter -->
      <div class="flex flex-wrap items-center justify-center gap-2 mb-12">
        {categories.map((cat, i) => (
          <button
            class:list={[
              'px-4 py-1.5 rounded-full text-sm font-medium transition-colors border filter-btn',
              i === 0
                ? 'bg-brand-accent text-white border-brand-accent'
                : 'border-brand-border text-brand-muted hover:border-brand-accent hover:text-brand-accent',
            ]}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>

      {projects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="portfolio-grid">
          {projects.map((project: any) => (
            <div data-category={project.data.category ?? 'All'} class="portfolio-card">
              <PortfolioCard
                title={project.data.title}
                description={project.data.description}
                href={`/portfolio/${project.slug}/`}
                image={project.data.coverImage}
                tags={project.data.tags?.map((t: any) => t.tag)}
                category={project.data.category}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-24 card max-w-md mx-auto">
          <p class="text-4xl font-bold gradient-text mb-4">...</p>
          <h2 class="font-semibold font-heading mb-2">Portfolio coming soon</h2>
          <p class="text-brand-muted text-sm">
            Add <code class="text-brand-accent">.mdx</code> files to <code class="text-brand-accent">src/content/portfolio/</code>
            or manage via TinaCMS and projects will appear here automatically.
          </p>
        </div>
      )}
    </div>
  </section>

  <CTABanner
    heading="Have a project in mind?"
    subheading="Let's add your success story to our portfolio."
    primaryCTA={{ label: 'Start your project', href: '/contact/' }}
    secondaryCTA={{ label: 'See our services', href: '/services/' }}
  />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.portfolio-card');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'All';

      buttons.forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle('bg-brand-accent',    isActive);
        b.classList.toggle('text-white',          isActive);
        b.classList.toggle('border-brand-accent', isActive);
        b.classList.toggle('text-brand-muted',    !isActive);
        b.classList.toggle('border-brand-border', !isActive);
      });

      cards.forEach((card) => {
        const show = cat === 'All' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>
