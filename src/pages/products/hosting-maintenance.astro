---
import ServiceLayout from '@/layouts/ServiceLayout.astro';

const plans = [
  {
    name: 'Basic',
    description: 'For small business websites.',
    price: '$100/mo',
    features: [
      'VPS hosting',
      'Quarterly backups',
      'Quarterly updates',
      'Basic security',
      'Domain and DNS management',
      'SSL certification',
      'Email and chat support',
    ],
    cta: 'Get started',
    highlighted: false,
  },
  {
    name: 'Advanced',
    description: 'For growing businesses and e-commerce.',
    price: '$220/mo',
    features: [
      'Dedicated VPS',
      'Monthly backups',
      'Monthly updates',
      'Advanced security',
      'Performance optimization',
      'Analytics and reporting',
      'Email, chat, and phone support',
    ],
    cta: 'Get started',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    description: 'For high-traffic sites with complex needs.',
    price: '$350/mo',
    features: [
      'Dedicated+ VPS',
      'Weekly backups',
      'Bi-monthly updates',
      'Hardened security',
      'CDN integration',
      'Live uptime monitoring',
      'Full analytics and priority support',
    ],
    cta: 'Contact us',
    highlighted: false,
  },
];
---

<ServiceLayout
  title="Hosting and maintenance | Pronova"
  description="High-performance VPS hosting with proactive maintenance. Keep your website fast, secure, and always online. Month-to-month — cancel anytime."
  badge="Hosting and maintenance"
  heading="A website without proper hosting is a "
  headingHighlight="liability."
  subheading="Month-to-month hosting and maintenance packages that keep your site fast, secure, and updated — without surprise invoices. Your site files and data are always yours."
  ctaHeading="Not sure which plan is right for you?"
  ctaSubheading="Talk to our team and we will recommend the best fit for your needs and budget."
>
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {plans.map((plan) => (
          <div class:list={['flex flex-col rounded-2xl p-8 border transition-all duration-300', plan.highlighted ? 'bg-gradient-brand border-transparent shadow-glow-violet' : 'card']}>
            <div class="mb-6">
              <h3 class:list={['font-bold text-xl font-heading mb-1', plan.highlighted ? 'text-white' : 'text-brand-text']}>{plan.name}</h3>
              <p class:list={['text-sm', plan.highlighted ? 'text-white/70' : 'text-brand-muted']}>{plan.description}</p>
            </div>
            <p class:list={['text-2xl font-bold mb-6', plan.highlighted ? 'text-white' : 'gradient-text']}>{plan.price}</p>
            <ul class="space-y-3 flex-1 mb-8">
              {plan.features.map((feature) => (
                <li class:list={['flex items-center gap-2.5 text-sm', plan.highlighted ? 'text-white/90' : 'text-brand-muted']}>
                  <svg class:list={['w-4 h-4 shrink-0', plan.highlighted ? 'text-white' : 'text-brand-accent']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href="/contact/"
              class:list={[
                'text-center px-6 py-3 rounded-lg font-semibold text-sm transition-colors',
                plan.highlighted
                  ? 'bg-white text-brand-accent hover:bg-white/90'
                  : 'btn-primary',
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
      <p class="text-brand-muted text-sm text-center mt-8">Every plan includes domain management, DNS and email configuration, SSL certification, and live uptime monitoring. Month-to-month — cancel anytime.</p>
    </div>
  </section>
</ServiceLayout>
