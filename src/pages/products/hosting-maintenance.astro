---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTABanner from '@/components/sections/CTABanner.astro';

const plans = [
  {
    name: 'Starter',
    description: 'Perfect for small business websites.',
    price: 'From $49/mo',
    features: [
      'VPS Hosting (2GB RAM)',
      'Free SSL Certificate',
      'Daily Backups',
      'Uptime Monitoring',
      'Monthly Security Scan',
      'Email Support',
    ],
    cta: 'Get Started',
    highlighted: false,
  },
  {
    name: 'Business',
    description: 'Best for growing businesses and e-commerce.',
    price: 'From $99/mo',
    features: [
      'VPS Hosting (4GB RAM)',
      'Free SSL Certificate',
      'Daily Backups',
      'Uptime Monitoring',
      'Weekly Security Scans',
      'Monthly Performance Report',
      'Plugin & Theme Updates',
      'Priority Support',
    ],
    cta: 'Get Started',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    description: 'For high-traffic sites with complex needs.',
    price: 'Custom',
    features: [
      'Dedicated VPS Resources',
      'CDN Integration',
      'Real-Time Monitoring',
      'Daily Security Scans',
      'Weekly Performance Reports',
      'Emergency Support (24/7)',
      'Quarterly Strategy Reviews',
    ],
    cta: 'Contact Us',
    highlighted: false,
  },
];
---

<BaseLayout
  title="Website Hosting & Maintenance Packages | Pronova Designs"
  description="High-performance VPS hosting and maintenance packages from Pronova Designs. Keep your website fast, secure, and always online."
>
  <section class="section pt-32 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none" />
    <div class="container max-w-4xl mx-auto">
      <a href="/products/" class="text-brand-muted text-sm hover:text-brand-accent transition-colors inline-flex items-center gap-1 mb-8">← All Products</a>
      <span class="badge mb-4">Hosting & Maintenance</span>
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6">
        Hosting That <span class="gradient-text">Goes Beyond the Basics</span>
      </h1>
      <p class="text-brand-muted text-lg leading-relaxed max-w-2xl">
        Our VPS hosting and maintenance packages are designed to ensure your website survives
        and thrives — with high-performance speed, extensive storage, and robust security.
      </p>
    </div>
  </section>

  <!-- Plans -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {plans.map((plan) => (
          <div class:list={['flex flex-col rounded-2xl p-8 border transition-all duration-300', plan.highlighted ? 'bg-gradient-brand border-transparent shadow-glow-blue' : 'card']}>
            <div class="mb-6">
              <h3 class:list={['font-bold text-xl font-heading mb-1', plan.highlighted ? 'text-white' : 'text-brand-text']}>{plan.name}</h3>
              <p class:list={['text-sm', plan.highlighted ? 'text-white/70' : 'text-brand-muted']}>{plan.description}</p>
            </div>
            <p class:list={['text-2xl font-bold mb-6', plan.highlighted ? 'text-white' : 'gradient-text']}>{plan.price}</p>
            <ul class="space-y-3 flex-1 mb-8">
              {plan.features.map((feature) => (
                <li class:list={['flex items-center gap-2.5 text-sm', plan.highlighted ? 'text-white/90' : 'text-brand-muted']}>
                  <svg class:list={['w-4 h-4 shrink-0', plan.highlighted ? 'text-white' : 'text-brand-accent']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href="/contact/"
              class:list={[
                'text-center px-6 py-3 rounded-lg font-semibold text-sm transition-colors',
                plan.highlighted
                  ? 'bg-white text-brand-accent hover:bg-white/90'
                  : 'btn-primary',
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner heading="Not Sure Which Plan is Right for You?" subheading="Talk to our team and we'll recommend the best fit." />
</BaseLayout>
