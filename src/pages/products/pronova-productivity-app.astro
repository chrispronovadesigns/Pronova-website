---
import ServiceLayout from '@/layouts/ServiceLayout.astro';

const features = [
  { title: 'Smart task management', desc: 'Capture, organize, and prioritize tasks with intelligent workflows.' },
  { title: 'Focus timer', desc: 'Built-in focus sessions with customizable work and break intervals.' },
  { title: 'Calendar integration', desc: 'Sync with Google Calendar and Outlook to see your full schedule.' },
  { title: 'Time zone support', desc: 'Work across multiple time zones without ever missing a meeting.' },
  { title: 'Productivity analytics', desc: 'See where your time goes and optimize your work patterns.' },
  { title: 'Team collaboration', desc: 'Share projects and tasks with remote teammates seamlessly.' },
];
---

<ServiceLayout
  title="Pronova productivity app | Pronova"
  description="Built for remote teams and growing businesses. Stay focused, organized, and productive with our purpose-built productivity platform."
  badge="Productivity app — coming soon"
  heading="Built for the location-independent "
  headingHighlight="professional."
  subheading="Stay organized, focused, and at your best no matter where you are. Purpose-built for remote teams and growing businesses."
  ctaHeading="Be the first to know"
  ctaSubheading="Join the waitlist and get early access when we launch."
>
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div class="card flex gap-4">
            <span class="text-lg font-bold gradient-text font-heading shrink-0">0{i + 1}</span>
            <div>
              <h3 class="font-semibold font-heading mb-1">{f.title}</h3>
              <p class="text-brand-muted text-sm leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
