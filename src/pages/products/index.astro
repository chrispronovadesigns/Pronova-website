---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import CTABanner from '@/components/sections/CTABanner.astro';

const products = [
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>`,
    title: 'Digital marketing playbook',
    description: 'The complete guide to growing your business online — strategy, tactics, and templates you can execute yourself.',
    href: '/products/digital-marketing-playbook/',
    badge: 'Guide',
    cta: 'Get the playbook',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: 'Pronova productivity app',
    description: 'Stay focused and organized with our productivity tool built for remote teams and growing businesses.',
    href: '/products/pronova-productivity-app/',
    badge: 'App',
    cta: 'Learn more',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" /></svg>`,
    title: 'Hosting and maintenance',
    description: 'High-performance VPS hosting with proactive maintenance so your site never misses a beat. Month-to-month.',
    href: '/products/hosting-maintenance/',
    badge: 'Service',
    cta: 'View plans',
  },
];
---

<BaseLayout
  title="Products | Pronova"
  description="Ready-made digital solutions — the Digital Marketing Playbook, Pronova Productivity App, and Hosting and Maintenance packages."
>
  <Hero
    badge="Products"
    heading="Ready-made solutions for "
    headingHighlight="digital growth."
    subheading="Purpose-built products designed to accelerate your digital journey — whether you need a strategy guide, a productivity tool, or rock-solid hosting."
    primaryCTA={{ label: 'Get a free consultation', href: '/contact/' }}
    secondaryCTA={{ label: 'View services', href: '/services/' }}
    showStats={false}
  />

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <div class="card flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <div class="text-brand-accent" set:html={product.icon} />
              <span class="badge">{product.badge}</span>
            </div>
            <h2 class="font-bold text-xl font-heading mb-3">{product.title}</h2>
            <p class="text-brand-muted text-sm leading-relaxed flex-1 mb-6">{product.description}</p>
            <a href={product.href} class="btn-primary justify-center text-sm">
              {product.cta}
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Need something custom?"
    subheading="Our products are great starting points — we can customize or build from scratch for your specific needs."
    primaryCTA={{ label: 'Talk to our team', href: '/contact/' }}
    secondaryCTA={{ label: 'View services', href: '/services/' }}
  />
</BaseLayout>
