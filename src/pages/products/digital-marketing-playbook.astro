---
import ServiceLayout from '@/layouts/ServiceLayout.astro';

const chapters = [
  'Digital marketing foundations', 'SEO strategy and keyword research', 'Local SEO and Google Business Profile',
  'Social media marketing', 'Paid advertising — Google and Meta', 'Email marketing and automation',
  'Video marketing and YouTube', 'Content marketing and blogging', 'Analytics and reporting',
  'Building your marketing stack',
];
---

<ServiceLayout
  title="Digital marketing playbook | Pronova"
  description="The complete digital marketing playbook — SEO, social media, paid ads, email, and more. Everything you need to grow your business online."
  badge="Digital product"
  heading="The complete guide to growing your business "
  headingHighlight="online."
  subheading="From SEO fundamentals to advanced paid advertising — everything you need to build and execute a winning digital marketing strategy. Strategy, tactics, and templates you can execute yourself."
  ctaHeading="Want us to do it for you?"
  ctaSubheading="Our team can implement your full digital marketing strategy — so you can focus on running your business."
>
  <section class="section">
    <div class="container max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold font-heading mb-8 text-center">What is inside</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {chapters.map((chapter, i) => (
          <div class="card flex items-center gap-3">
            <span class="text-brand-accent font-mono text-sm font-bold shrink-0">{String(i + 1).padStart(2, '0')}</span>
            <span class="text-brand-text text-sm font-medium">{chapter}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</ServiceLayout>
