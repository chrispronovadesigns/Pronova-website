---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found | Pronova"
  description="The page you're looking for doesn't exist."
  noindex
>
  <section class="section min-h-[80vh] flex items-center justify-center">
    <div class="container text-center max-w-xl mx-auto">
      <p class="text-8xl font-bold gradient-text font-heading mb-4">404</p>
      <h1 class="text-3xl font-bold font-heading mb-4">Page not found</h1>
      <p class="text-brand-muted mb-10 leading-relaxed">
        Looks like this page took a wrong turn. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary">Go home</a>
        <a href="/contact/" class="btn-secondary">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>
