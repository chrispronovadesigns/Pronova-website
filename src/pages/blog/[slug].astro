}

import BlogLayout from '@/layouts/BlogLayout.astro';

interface Props {
  title: string;
  description: string;
  publishedDate: string;
  author?: string;
  category?: string;
  heroImage?: string;
  readingTime?: string;
  content: string;
}

const { title, description, publishedDate, author, category, heroImage, readingTime } = Astro.props;
---

<BlogLayout
  title={title}
  description={description}
  publishedDate={publishedDate}
  author={author}
  category={category}
  image={heroImage}
  readingTime={readingTime}
>
  <slot />
</BlogLayout>
