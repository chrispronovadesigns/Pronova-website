---
/**
 * Dynamic blog post route.
 *
 * Currently reads from Astro content collections (src/content/blog/*.mdx).
 * When you port WordPress posts into src/content/blog/ as .mdx files,
 * they will automatically appear here.
 *
 * TODO: once tina/__generated__ is available, replace getStaticPaths with:
 *   import { client } from '@/tina/__generated__/client';
 *   const posts = await client.queries.postConnection();
 */
import { getCollection } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';

export async function getStaticPaths() {
  let posts: any[] = [];
  try {
    posts = await getCollection('post');
  } catch {
    // Collection doesn't exist yet — return empty until content is added
    return [];
  }
  return posts
    .filter((p: any) => !p.data.draft)
    .map((p: any) => ({
      params: { slug: p.slug },
      props: { post: p },
    }));
}

const { post } = Astro.props;
const { Content } = post ? await post.render() : { Content: null };
---

{post && Content ? (
  <BlogLayout
    title={post.data.seo?.metaTitle ?? post.data.title}
    description={post.data.seo?.metaDescription ?? post.data.description}
    publishedDate={post.data.publishedDate}
    author={post.data.author ?? 'Pronova Designs'}
    category={post.data.category}
    image={post.data.seo?.ogImage ?? post.data.heroImage}
    readingTime={post.data.readingTime}
  >
    <Content />
  </BlogLayout>
) : (
  <p>Post not found.</p>
)}
